// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 0. CRM & CORE
model Customer {
  id               String   @id @default(uuid())
  tipo_documento   String   
  numero_documento String   @unique
  nombre           String
  telefono         String?
  email            String?
  direccion        String?
  created_at       DateTime @default(now())

  invoices        Invoice[]
  serviceOrders   ServiceOrder[]
  @@map("clientes")
}

// 1. CONFIGURACIÓN DE INVENTARIO (MAESTROS)
model Category {
  id          String   @id @default(uuid())
  nombre      String   @unique
  descripcion String?
  products    Product[]
  @@map("categorias")
}

model Brand {
  id          String   @id @default(uuid())
  nombre      String   @unique
  products    Product[]
  @@map("marcas")
}

model Attribute {
  id          String   @id @default(uuid())
  nombre      String   @unique // Ej: RAM, Almacenamiento, Color
  tipo        String   @default("TEXTO") // TEXTO, NUMERICO
  values      ProductAttribute[]
  @@map("caracteristicas")
}

// 2. CATÁLOGO DE PRODUCTOS
model Product {
  id                String   @id @default(uuid())
  sku               String   @unique
  nombre            String
  categoryId        String
  category          Category @relation(fields: [categoryId], references: [id])
  brandId           String
  brand             Brand    @relation(fields: [brandId], references: [id])
  
  precios           Json     // { "retail": 0, "wholesale": 0 }
  precio_compra     Decimal  @db.Decimal(10, 2)
  stock_minimo      Int      @default(5)
  requiere_imei     Boolean  @default(false)
  created_at        DateTime @default(now())

  items             StockItem[]
  attributes        ProductAttribute[]
  @@map("productos")
}

model ProductAttribute {
  id          String    @id @default(uuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  attributeId String
  attribute   Attribute @relation(fields: [attributeId], references: [id])
  valor       String    // El valor real: ej "8GB", "Negro"
  @@map("productos_caracteristicas")
}

// 3. COMPRAS Y PROVEEDORES
model Provider {
  id          String   @id @default(uuid())
  ruc         String   @unique
  nombre      String
  contacto    String?
  telefono    String?
  purchases   Purchase[]
  @@map("proveedores")
}

model Purchase {
  id              String   @id @default(uuid())
  numero_factura  String   @unique
  providerId      String
  provider        Provider @relation(fields: [providerId], references: [id])
  total_compra    Decimal  @db.Decimal(10, 2)
  fecha_compra    DateTime @default(now())
  items           PurchaseItem[]
  @@map("compras")
}

model PurchaseItem {
  id          String   @id @default(uuid())
  purchaseId  String
  purchase    Purchase @relation(fields: [purchaseId], references: [id])
  productId   String
  cantidad    Int
  precio_unit Decimal  @db.Decimal(10, 2)
  stockItems  StockItem[]
  @@map("compras_items")
}

// 4. MOVIMIENTOS Y UNIDADES
model StockItem {
  id                String   @id @default(uuid())
  productId         String
  product           Product  @relation(fields: [productId], references: [id])
  purchaseItemId    String?
  purchaseItem      PurchaseItem? @relation(fields: [purchaseItemId], references: [id])
  
  imei              String?  @unique
  iccid             String?  @unique
  estado_inventario String   @default("Disponible")
  created_at        DateTime @default(now())
  @@map("items_inventario")
}

// 5. OPERACIONES (VENTAS Y SOPORTE)
model ServiceOrder {
  id                        String   @id @default(uuid())
  numero_orden              Int      @unique @default(autoincrement())
  clienteId                 String
  cliente                   Customer @relation(fields: [clienteId], references: [id])
  imei_equipo               String
  marca_modelo              String
  estado_servicio           String   @default("RECIBIDO")
  presupuesto_estimado      Decimal? @db.Decimal(10, 2)
  adelanto                  Decimal  @default(0) @db.Decimal(10, 2)
  created_at                DateTime @default(now())
  @@map("ordenes_servicio")
}

model Invoice {
  id                      String   @id @default(uuid())
  tipo_documento          String
  serie_correlativo       String   @unique
  clienteId               String
  cliente                 Customer @relation(fields: [clienteId], references: [id])
  igv_total               Decimal  @db.Decimal(10, 2)
  total_venta             Decimal  @db.Decimal(10, 2)
  created_at              DateTime @default(now())
  @@map("facturas")
}
