// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. CRM Y CLIENTES
model Cliente {
  id               String   @id @default(uuid())
  tipo_documento   String   
  numero_documento String   @unique
  nombre           String
  telefono         String?
  email            String?
  direccion        String?
  created_at       DateTime @default(now())

  facturas        Factura[]
  ordenesServicio OrdenServicio[]
  @@map("clientes")
}

// 2. CONFIGURACIÓN DE INVENTARIO (MAESTROS)
model Categoria {
  id          String   @id @default(uuid())
  nombre      String   @unique
  descripcion String?
  activo      Boolean  @default(true)
  productos   Producto[]
  @@map("categorias")
}

model Marca {
  id          String   @id @default(uuid())
  nombre      String   @unique
  activo      Boolean  @default(true)
  productos   Producto[]
  @@map("marcas")
}

model Caracteristica {
  id          String   @id @default(uuid())
  nombre      String   @unique 
  tipo        String   @default("TEXTO")
  activo      Boolean  @default(true)
  valores     ProductoCaracteristica[]
  @@map("caracteristicas")
}

// 3. CATÁLOGO DE PRODUCTOS
model Producto {
  id                String   @id @default(uuid())
  sku               String   @unique
  nombre            String
  categoriaId       String
  categoria         Categoria @relation(fields: [categoriaId], references: [id])
  marcaId           String
  marca             Marca    @relation(fields: [marcaId], references: [id])
  
  precios           Json     
  precio_compra     Decimal  @db.Decimal(10, 2)
  stock_minimo      Int      @default(5)
  requiere_imei     Boolean  @default(false)
  created_at        DateTime @default(now())

  unidades          ItemInventario[]
  caracteristicas   ProductoCaracteristica[]
  @@map("productos")
}

model ProductoCaracteristica {
  id               String    @id @default(uuid())
  productoId       String
  producto         Producto   @relation(fields: [productoId], references: [id])
  caracteristicaId String
  caracteristica   Caracteristica @relation(fields: [caracteristicaId], references: [id])
  valor            String    
  @@map("productos_caracteristicas")
}

// 4. COMPRAS Y PROVEEDORES
model Proveedor {
  id          String   @id @default(uuid())
  ruc         String   @unique
  nombre      String
  contacto    String?
  telefono    String?
  activo      Boolean  @default(true)
  compras     Compra[]
  @@map("proveedores")
}

model Compra {
  id              String   @id @default(uuid())
  numero_factura  String   @unique
  proveedorId      String
  proveedor        Proveedor @relation(fields: [proveedorId], references: [id])
  total_compra    Decimal  @db.Decimal(10, 2)
  fecha_compra    DateTime @default(now())
  detalles        DetalleCompra[]
  @@map("compras")
}

model DetalleCompra {
  id          String   @id @default(uuid())
  compraId    String
  compra      Compra   @relation(fields: [compraId], references: [id])
  productoId  String
  cantidad    Int
  precio_unit Decimal  @db.Decimal(10, 2)
  unidades    ItemInventario[]
  @@map("compras_detalles")
}

// 5. UNIDADES FÍSICAS
model ItemInventario {
  id                String   @id @default(uuid())
  productoId         String
  producto           Producto  @relation(fields: [productoId], references: [id])
  detalleCompraId    String?
  detalleCompra      DetalleCompra? @relation(fields: [detalleCompraId], references: [id])
  
  imei              String?  @unique
  iccid             String?  @unique
  estado_inventario String   @default("Disponible")
  created_at        DateTime @default(now())
  @@map("items_inventario")
}

// 6. OPERACIONES
model OrdenServicio {
  id                        String   @id @default(uuid())
  numero_orden              Int      @unique @default(autoincrement())
  clienteId                 String
  cliente                   Cliente @relation(fields: [clienteId], references: [id])
  imei_equipo               String
  marca_modelo              String
  estado_servicio           String   @default("RECIBIDO")
  presupuesto_estimado      Decimal? @db.Decimal(10, 2)
  adelanto                  Decimal  @default(0) @db.Decimal(10, 2)
  created_at                DateTime @default(now())
  @@map("ordenes_servicio")
}

model Factura {
  id                      String   @id @default(uuid())
  tipo_documento          String
  serie_correlativo       String   @unique
  clienteId               String
  cliente                 Cliente @relation(fields: [clienteId], references: [id])
  igv_total               Decimal  @db.Decimal(10, 2)
  total_venta             Decimal  @db.Decimal(10, 2)
  created_at              DateTime @default(now())
  @@map("facturas")
}
