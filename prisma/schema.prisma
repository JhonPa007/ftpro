// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. CRM Y CLIENTES
model Cliente {
  id               String   @id @default(uuid())
  tipo_documento   String   
  numero_documento String   @unique
  nombre           String
  telefono         String?
  email            String?
  direccion        String?
  created_at       DateTime @default(now())

  ventas           Venta[]
  ordenesServicio OrdenServicio[]
  @@map("clientes")
}

// 2. CONFIGURACIÓN DE INVENTARIO (MAESTROS)
model Categoria {
  id          String   @id @default(uuid())
  nombre      String   @unique
  descripcion String?
  activo      Boolean  @default(true)
  productos   Producto[]
  @@map("categorias")
}

model Marca {
  id          String   @id @default(uuid())
  nombre      String   @unique
  activo      Boolean  @default(true)
  productos   Producto[]
  @@map("marcas")
}

model Caracteristica {
  id          String   @id @default(uuid())
  nombre      String   @unique 
  tipo        String   @default("TEXTO")
  activo      Boolean  @default(true)
  valores     ProductoCaracteristica[]
  @@map("caracteristicas")
}

// 3. CATÁLOGO DE PRODUCTOS
model Producto {
  id                String   @id @default(uuid())
  sku               String   @unique
  nombre            String
  categoriaId       String
  categoria         Categoria @relation(fields: [categoriaId], references: [id])
  marcaId           String
  marca             Marca    @relation(fields: [marcaId], references: [id])
  
  precios           Json     
  precio_compra     Decimal  @db.Decimal(10, 2)
  stock_minimo      Int      @default(5)
  requiere_imei     Boolean  @default(false)
  created_at        DateTime @default(now())

  unidades          ItemInventario[]
  caracteristicas   ProductoCaracteristica[]
  ventas            DetalleVenta[]
  @@map("productos")
}

model ProductoCaracteristica {
  id               String    @id @default(uuid())
  productoId       String
  producto         Producto   @relation(fields: [productoId], references: [id])
  caracteristicaId String
  caracteristica   Caracteristica @relation(fields: [caracteristicaId], references: [id])
  valor            String    
  @@map("productos_caracteristicas")
}

// 4. COMPRAS Y PROVEEDORES
model Proveedor {
  id          String   @id @default(uuid())
  ruc         String   @unique
  nombre      String
  contacto    String?
  telefono    String?
  email       String?
  direccion   String?
  activo      Boolean  @default(true)
  compras     Compra[]
  @@map("proveedores")
}

model Compra {
  id              String   @id @default(uuid())
  numero_factura  String   @unique
  proveedorId      String
  proveedor        Proveedor @relation(fields: [proveedorId], references: [id])
  total_compra    Decimal  @db.Decimal(10, 2)
  fecha_compra    DateTime @default(now())
  detalles        DetalleCompra[]
  @@map("compras")
}

model DetalleCompra {
  id          String   @id @default(uuid())
  compraId    String
  compra      Compra   @relation(fields: [compraId], references: [id])
  productoId  String
  cantidad    Int
  precio_unit Decimal  @db.Decimal(10, 2)
  unidades    ItemInventario[]
  @@map("compras_detalles")
}

// 5. UNIDADES FÍSICAS
model ItemInventario {
  id                String   @id @default(uuid())
  productoId         String
  producto           Producto  @relation(fields: [productoId], references: [id])
  detalleCompraId    String?
  detalleCompra      DetalleCompra? @relation(fields: [detalleCompraId], references: [id])
  
  imei              String?  @unique
  iccid             String?  @unique
  estado_inventario String   @default("Disponible")
  created_at        DateTime @default(now())
  @@map("items_inventario")
}

// 6. OPERACIONES
model OrdenServicio {
  id                        String   @id @default(uuid())
  numero_orden              Int      @unique @default(autoincrement())
  clienteId                 String
  cliente                   Cliente @relation(fields: [clienteId], references: [id])
  imei_equipo               String
  marca_modelo              String
  estado_servicio           String   @default("RECIBIDO")
  presupuesto_estimado      Decimal? @db.Decimal(10, 2)
  adelanto                  Decimal  @default(0) @db.Decimal(10, 2)
  created_at                DateTime @default(now())
  @@map("ordenes_servicio")
}

model Venta {
  id              String   @id @default(uuid())
  numero_venta    Int      @unique @default(autoincrement())
  tipo_documento  String   @default("BOLETA")
  serie           String?  // Ej: B001, F001, NV01
  correlativo     Int?     
  clienteId       String
  cliente         Cliente  @relation(fields: [clienteId], references: [id])
  sucursalId      String?
  sucursal        Sucursal? @relation(fields: [sucursalId], references: [id])
  total           Decimal  @db.Decimal(10, 2)
  estado_pago     String   @default("PAGADO")
  detalles        DetalleVenta[]
  created_at      DateTime @default(now())
  @@map("ventas")
}

model Sucursal {
  id            String   @id @default(uuid())
  nombre        String
  direccion     String?
  ubigeo        String?
  serie_boleta  String   @default("B001")
  serie_factura String   @default("F001")
  serie_nota    String   @default("NV01")
  activo        Boolean  @default(true)
  ventas        Venta[]
  @@map("sucursales")
}

model DetalleVenta {
  id              String   @id @default(uuid())
  ventaId         String
  venta           Venta    @relation(fields: [ventaId], references: [id])
  productoId       String
  producto         Producto @relation(fields: [productoId], references: [id])
  unitId          String?  // ID del ItemInventario especifico (ej: IMEI)
  cantidad        Int
  precio_unit     Decimal  @db.Decimal(10, 2)
  @@map("ventas_detalles")
}

model Configuracion {
  id              String   @id @default("default")
  empresa_nombre  String   @default("FTPRO")
  empresa_ruc     String?
  empresa_logo    String?
  tema            String   @default("Oscuro")
  color_acento    String   @default("#00fff2")
  sunat_api_key   String?
  modulos         Json     @default("[]")
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  @@map("configuracion")
}
model Usuario {
  id              String   @id @default(uuid())
  nombre          String
  username        String   @unique
  password        String
  rol             String   @default("Vendedor")
  permisos        Json     @default("[]") // Lista de modulos permitidos
  activo          Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  @@map("usuarios")
}
